{
  "name": "cartographer-monorepo",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@cartographer/web",
    "dev:api": "turbo run start:dev --filter=@cartographer/api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "nanoid": "^5.1.9",
    "source-map-js": "^1.2.1",
    "turbo": "^2.5.8"
  }
}
