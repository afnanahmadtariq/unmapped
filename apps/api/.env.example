# ──────────────────────────────────────────────────────────────────────────────
# Cartographer — NestJS API environment variables
# Copy this file to .env and fill in real values. Never commit .env.
# All variables are validated at startup via Zod (src/infra/config/env.schema.ts).
# ──────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# URL of the Next.js frontend — used to configure CORS allow-list.
WEB_ORIGIN=http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Full connection URL (supports Neon, Supabase, self-hosted Postgres, etc.).
# `sslmode=require` is recommended for cloud-hosted databases.
# `uselibpqcompat=true` opts in to libpq SSL semantics today and silences the
# pg-connection-string v3 deprecation warning printed at boot.
POSTGRES_URL=postgresql://user:password@host:5432/dbname?sslmode=require&uselibpqcompat=true

# TypeORM controls — keep both false in production; enable TYPEORM_SYNC only
# during local schema iteration (never on a shared/production database).
TYPEORM_SYNC=false
TYPEORM_LOGGING=false

# ── Milvus / Zilliz Cloud ─────────────────────────────────────────────────────
# Public Endpoint from the cluster (HTTPS) — must be a real URL, no angle brackets.
# Always include the port (`:443` for HTTPS or `:19530` for self-hosted) — the
# milvus2-sdk-node logs a warning otherwise.
# Example shape: https://in01-xxxxxxxx.api.gcp-us-west1.zillizcloud.com:443
MILVUS_URI=https://in01-0000000000000000.api.gcp-us-west1.zillizcloud.com:443
# Option A: cluster API key (Zilliz console → API key).
# Option B: leave MILVUS_TOKEN empty and set MILVUS_USER + MILVUS_PASSWORD (db user
#   → SDK sends token as "user:password", which is what Zilliz expects for DB users).
# Quote the password if it contains ; # | or spaces.
MILVUS_TOKEN=
MILVUS_USER=
MILVUS_PASSWORD=
# Database name inside the cluster (default is fine for a single-tenant setup).
MILVUS_DATABASE=default

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required for skill extraction and opportunity narrative generation.
ANTHROPIC_API_KEY=sk-ant-api03-...
# Model slug — claude-sonnet-4-5 is used by default.
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Embeddings ────────────────────────────────────────────────────────────────
# Provider to use for generating text embeddings. voyage | openai | cohere
EMBEDDINGS_PROVIDER=voyage
# API key for the chosen provider (Voyage, OpenAI, or Cohere).
EMBEDDINGS_API_KEY=pa-...
# Model name — must match the provider.
#   voyage:  voyage-3 (1024-dim), voyage-3-lite (512-dim)
#   openai:  text-embedding-3-small (1536-dim)
#   cohere:  embed-english-v3.0 (1024-dim)
EMBEDDINGS_MODEL=voyage-3
# Output dimensionality — must match the collection schema in Milvus.
EMBEDDINGS_DIM=1024

# ── Tavily (optional) ─────────────────────────────────────────────────────────
# Used by the /jobs endpoint to surface live job listings.
# If omitted the endpoint returns an empty results list gracefully.
TAVILY_API_KEY=tvly-...

# ── SMTP / Email (optional) ───────────────────────────────────────────────────
# Used by the /notifications/email endpoint. If omitted the endpoint returns
# a mailto: link instead of sending a real email.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=
SMTP_FROM="Cartographer <no-reply@example.com>"
# Set to true to use TLS from the first connection (port 465); false uses STARTTLS.
SMTP_SECURE=false

# ── End-user accounts (optional) ──────────────────────────────────────────────
# When enabled, visitors can sign up / log in to save their wizard profile and
# come back later to refreshed insights. Independent from the admin auth above:
# sessions live in the `cartographer_user_session` cookie (admin uses a different
# cookie). Disable signups by flipping USER_SIGNUP_ENABLED=false; existing
# accounts can still log in. The JWT secret is required to enable the feature.
USER_AUTH_ENABLED=true
USER_SIGNUP_ENABLED=true
USER_JWT_SECRET=replace-me-with-a-long-random-string-at-least-16-chars
USER_JWT_TTL_HOURS=168

# ── Startup harvest ───────────────────────────────────────────────────────────
# When true (default), the API runs every registered harvester sequentially a
# few seconds after boot, skipping sources whose last successful run is
# younger than HARVEST_STARTUP_FRESHNESS_HOURS. Set to false to disable.
HARVEST_ON_STARTUP=true
HARVEST_STARTUP_DELAY_MS=5000
HARVEST_STARTUP_FRESHNESS_HOURS=24
