# ──────────────────────────────────────────────────────────────────────────────
# Cartographer — Next.js web app environment variables
# Copy this file to .env.local (preferred) or .env and fill in real values.
# Never commit files containing real credentials.
#
# NEXT_PUBLIC_* variables are embedded into the client bundle at build time —
# do not put secrets in them.
# ──────────────────────────────────────────────────────────────────────────────

# ── NestJS API base URL ───────────────────────────────────────────────────────
# The Next.js app fetches all data from the NestJS API. This variable must be
# set to the fully-qualified URL of the running API server.
#
#   Local dev:   http://localhost:4000   (default NestJS PORT)
#   Production:  https://api.yourdomain.com
#
# Note: the trailing slash is stripped automatically by apiClient.ts.
NEXT_PUBLIC_API_URL=http://localhost:4000
