# ──────────────────────────────────────────────────────────────────────────────
# Cartographer — Next.js web app environment variables
# Copy this file to .env.local (preferred) or .env and fill in real values.
# Never commit files containing real credentials.
#
# NEXT_PUBLIC_* variables are embedded into the client bundle at build time —
# do not put secrets in them.
# ──────────────────────────────────────────────────────────────────────────────

# ── NestJS API base URL (server-only, preferred) ──────────────────────────────
# The browser never reads this — it always calls the same-origin proxy at
# /api/proxy. Only the Next.js server uses this value to forward requests to
# the upstream API. Because it is NOT a NEXT_PUBLIC_* variable, changing it
# only requires restarting the server (no rebuild).
#
#   Local dev:   http://localhost:4000   (default NestJS PORT)
#   Production:  https://unmappedapi-production-xxxx.up.railway.app
#
# Note: the trailing slash is stripped automatically.
API_URL=http://localhost:4000

# ── Legacy: NEXT_PUBLIC_API_URL (back-compat fallback) ────────────────────────
# Kept for back-compat only. If API_URL is unset, the server falls back to
# this value. Do NOT use this for new deploys — it bakes the API URL into
# the client bundle and requires a rebuild whenever it changes.
# NEXT_PUBLIC_API_URL=http://localhost:4000
